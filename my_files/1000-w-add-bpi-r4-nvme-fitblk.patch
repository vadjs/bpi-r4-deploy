 static int fitblk_match_of_node(struct device *dev, const void *np)
 {
-	int ret;
-
-	ret = device_match_of_node(dev, np);
-	if (ret)
-		return ret;
+	struct device *d;
 
 	/*
-	 * To match ubiblock and mtdblock devices by their parent ubi
-	 * or mtd device, also consider block device parent
+	 * Only match partition block devices — whole disk devices do not
+	 * contain a uImage.FIT directly and would cause parse errors.
 	 */
-	if (!dev->parent)
+	if (!bdev_is_partition(dev_to_bdev(dev)))
 		return 0;
 
-	return device_match_of_node(dev->parent, np);
+	/*
+	 * Walk the full device parent chain to match block devices whose
+	 * ancestor platform device corresponds to the rootdisk OF node.
+	 *
+	 * This is required for NVMe devices connected via PCIe: the NVMe
+	 * and PCI bridge devices do not have OF nodes assigned, but the
+	 * parent PCIe controller platform device (e.g. pcie@11290000) does.
+	 *
+	 * For MTD/UBI backed devices the existing single-level parent match
+	 * is preserved as part of this loop.
+	 */
+	for (d = dev; d; d = d->parent) {
+		if (device_match_of_node(d, np))
+			return 1;
+	}
+
+	return 0;
 }
 
 static int fitblk_probe(struct platform_device *pdev)
 {
-	struct device *dev;
+	struct device *dev = NULL;
+	int ret = -EPROBE_DEFER;
 
-	dev = class_find_device(&block_class, NULL, rootdisk, fitblk_match_of_node);
-	if (!dev)
-		return -EPROBE_DEFER;
+	/*
+	 * Iterate over all matching block devices — we need to find the one
+	 * that actually contains a valid FIT image. For NVMe, the FIT image
+	 * is on a specific partition (e.g. nvme0n1p2), not the first one.
+	 */
+	while (true) {
+		struct device *next;
+
+		next = class_find_device(&block_class, dev, rootdisk,
+					 fitblk_match_of_node);
+		if (dev)
+			put_device(dev);
+
+		if (!next)
+			break;
+
+		dev = next;
+		ret = parse_fit_on_dev(dev);
+		if (ret == 0) {
+			put_device(dev);
+			return 0;
+		}
+	}
 
-	return parse_fit_on_dev(dev);
+	return -EPROBE_DEFER;
 }
 
 static struct platform_driver fitblk_driver = {
 	.probe		= fitblk_probe,
 	.driver		= {
-		.name   = "fitblk",
+		.name	= "fitblk",
 	},
 };
 
